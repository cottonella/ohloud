{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ohloud",
  "version": "../package.json",
  "identifier": "com.ohloud.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run generate",
    "frontendDist": "../.output/public"
  },
  "app": {
    "windows": [
      {
        "title": "ohloud",
        "width": 1200,
        "height": 800,
        "minWidth": 400,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Send secrets by sound.",
    "longDescription": "Send a secret from one device to another using only sound — no server, no internet, no pairing. Everything runs locally and offline.",
    "macOS": {
      "entitlements": "./Entitlements.plist"
    }
  }
}
