{
  "version": "2.0.0",
  "tasks": [
    {
      // Starts `nuxt dev` and signals "ready" once the server is listening,
      // so the Tauri/website debug configs can wait for it via preLaunchTask.
      "label": "ui:dev",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": {
        "owner": "nuxt",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Nuxt.*",
          "endsPattern": ".*(Local:|localhost:3000).*"
        }
      }
    },
    {
      // One-shot static build into .output/public (what the release build embeds).
      "label": "ui:build",
      "type": "npm",
      "script": "generate",
      "problemMatcher": []
    }
  ]
}
