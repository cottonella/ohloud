{
  "version": "0.2.0",
  "configurations": [
    {
      // Debug the Tauri app (Rust side) against the live Nuxt dev server.
      // Needs the CodeLLDB extension (vadimcn.vscode-lldb) and the Rust
      // toolchain. Starts `nuxt dev`, cargo-builds the debug binary, and
      // launches it pointed at the dev server (devUrl in tauri.conf.json).
      "type": "lldb",
      "request": "launch",
      "name": "Tauri Development Debug",
      "cargo": {
        "args": [
          "build",
          "--manifest-path=./src-tauri/Cargo.toml",
          "--no-default-features"
        ]
      },
      "preLaunchTask": "ui:dev"
    },
    {
      // Debug the Tauri app against the generated static site (production shape).
      "type": "lldb",
      "request": "launch",
      "name": "Tauri Production Debug",
      "cargo": {
        "args": [
          "build",
          "--release",
          "--manifest-path=./src-tauri/Cargo.toml"
        ]
      },
      "preLaunchTask": "ui:build"
    },
    {
      // Debug the app as a plain WEBSITE in Chrome (no Tauri, no Rust needed).
      "name": "Website (Chrome)",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "ui:dev",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/app"
    }
  ]
}
