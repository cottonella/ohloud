{
  "version": "0.2.0",
  "configurations": [
    {
      // Debug the Electron MAIN process (electron/main.ts, via sourcemaps).
      // Builds the dev electron bundle + starts nuxt dev first, launches
      // Electron pointed at the dev server, and exposes the renderer over
      // CDP port 9223 for the renderer config.
      "name": "Electron: Main",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "debug:prepare",
      "runtimeExecutable": "${workspaceFolder}/node_modules/electron/dist/electron",
      "windows": {
        "runtimeExecutable": "${workspaceFolder}/node_modules/electron/dist/electron.exe"
      },
      "osx": {
        "runtimeExecutable": "${workspaceFolder}/node_modules/electron/dist/Electron.app/Contents/MacOS/Electron"
      },
      "args": [".", "--remote-debugging-port=9223"],
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/electron/dist/**/*.cjs"],
      "outputCapture": "std",
      "console": "integratedTerminal"
    },
    {
      // Debug the RENDERER (the Nuxt site running inside Electron).
      // Attaches to the CDP port opened by the "Electron: Main" config.
      "name": "Electron: Renderer",
      "type": "chrome",
      "request": "attach",
      "port": 9223,
      "webRoot": "${workspaceFolder}/app",
      "timeout": 30000,
      "restart": true
    },
    {
      // Debug the app as a plain WEBSITE in Chrome (no Electron).
      "name": "Website (Chrome)",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "nuxt:dev",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/app"
    }
  ],
  "compounds": [
    {
      // One click to debug both the Electron main process and the renderer.
      "name": "Electron: Main + Renderer",
      "configurations": ["Electron: Main", "Electron: Renderer"],
      "stopAll": true,
      "presentation": { "order": 1 }
    }
  ]
}
