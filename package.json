{
  "name": "ohloud",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Nuxt 4 app that also runs as a fully-local Electron desktop app",
  "author": "cottonella",
  "license": "AGPL-3.0-only",
  "main": "electron/dist/main.cjs",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "postinstall": "nuxt prepare",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "electron:dev": "vite build --mode development --config electron/vite.config.ts && concurrently -k -n nuxt,vite,electron -c blue,yellow,magenta \"nuxt dev\" \"vite build --watch --mode development --config electron/vite.config.ts\" \"nodemon --exitcrash --watch \\\"electron/dist/**\\\" --exec \\\"wait-on tcp:127.0.0.1:3000 && electron . --remote-debugging-port=9223\\\"\"",
    "build": "concurrently -n nuxt,electron -c blue,magenta \"nuxt generate\" \"vite build --config electron/vite.config.ts\"",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "lint": "eslint .",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "bench": "tsx bench/run.ts"
  },
  "build": {
    "appId": "com.example.ohloud",
    "productName": "ohloud",
    "icon": "build/icon.png",
    "files": [
      "electron/dist/**/*",
      ".output/public/**/*"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": [
        "zip"
      ]
    },
    "mac": {
      "target": [
        "zip"
      ],
      "extendInfo": {
        "NSMicrophoneUsageDescription": "ohloud listens through the microphone to receive secrets sent as sound."
      }
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "dependencies": {
    "@fontsource/kanchenjunga": "^5.2.2",
    "@fontsource/pattaya": "^5.2.8"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.1.0",
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@scure/base": "^2.2.0",
    "@tailwindcss/vite": "4.3.2",
    "@trpc/client": "11.18.0",
    "@trpc/server": "11.18.0",
    "@types/canvas-confetti": "^1.9.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "canvas-confetti": "^1.9.4",
    "concurrently": "10.0.3",
    "daisyui": "5.6.10",
    "electron": "43.0.0",
    "electron-builder": "26.15.3",
    "eslint": "10.6.0",
    "eslint-plugin-format": "2.0.1",
    "fflate": "^0.8.3",
    "nodemon": "3.1.14",
    "nuxt": "4.4.8",
    "tailwindcss": "4.3.2",
    "tsx": "^4.22.5",
    "vitest": "^4.1.9",
    "vue": "latest",
    "vue-tsc": "^3.3.6",
    "wait-on": "9.0.10",
    "zod": "4.4.3"
  }
}
